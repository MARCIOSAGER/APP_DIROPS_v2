# ============================================================
# Credenciais para migracao Base44 -> Supabase
# ============================================================
# Copie este arquivo para .env.migration e preencha os valores
# NUNCA comite o .env.migration!
# ============================================================

# Base44 (origem)
BASE44_API_KEY=sua_api_key_aqui
BASE44_APP_ID=seu_app_id_aqui

# Supabase (destino)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
